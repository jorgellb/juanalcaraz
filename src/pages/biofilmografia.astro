---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const bioItems = await getCollection('bio');
const sortedBio = bioItems.sort((a, b) => a.data.order - b.data.order);

const pageTitle = 'Trayectoria - Juan Alcazar';
const pageDescription = 'Cineasta, visionario y explorador visual. Descubre la trayectoria y filmografía de Juan Alcazar.';
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="bio-hero">
    <div class="hero-bg">
      <div class="hero-overlay"></div>
      <div class="hero-flare"></div>
    </div>
    <div class="container hero-container">
      <div class="hero-content">
        <span class="hero-tag magic-reveal">EL RELATO VISUAL</span>
        <h1 class="hero-title magic-reveal" style="transition-delay: 0.2s">BIO / FILMOGRAFÍA</h1>
        <div class="hero-line magic-reveal" style="transition-delay: 0.4s"></div>
      </div>
    </div>
  </section>

  <section class="bio-intro section-padding">
    <div class="container narrow">
      <div class="intro-grid">
        <div class="intro-image-wrap magic-reveal">
          <div class="intro-image">
            <img src="https://images.unsplash.com/photo-1478720568477-152d9b164e26?auto=format&fit=crop&q=80&w=1200" alt="Juan Alcazar - Cineasta" />
            <div class="image-overlay"></div>
          </div>
          <div class="frame-decoration"></div>
        </div>
        <div class="intro-text-wrap">
          <h2 class="section-label magic-reveal">LA VISIÓN</h2>
          <div class="intro-p magic-reveal" style="transition-delay: 0.2s">
            <p>Juan Alcazar es un cineasta cuya visión trasciende los límites de la narrativa convencional, fusionando estética visual de vanguardia con historias profundamente humanas.</p>
            <p>Cada plano es una declaración de intenciones, cada corte un pulso emocional. Su trabajo explora la intersección entre la luz, el silencio y la verdad cruda de la experiencia humana.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bio-timeline section-padding">
    <div class="container">
      <div class="timeline-header magic-reveal">
        <h2 class="timeline-title-main">CRONOLOGÍA SELECTA</h2>
        <span class="timeline-subtitle">TRAYECTORIA & HITOS FÍLMICOS</span>
      </div>
      
      <div class="timeline-grid">
        <div class="timeline-line"></div>
        {sortedBio.map((item, index) => (
          <article class="timeline-entry magic-reveal" style={`transition-delay: ${index * 0.1}s`}>
            <div class="timeline-dot"></div>
            <div class="timeline-item-content">
              <header class="timeline-item-header">
                <span class="date">{item.data.dateLabel}</span>
                <h3 class="title">{item.data.title}</h3>
              </header>
              <div class="body">
                <p>{item.data.description}</p>
              </div>
            </div>
            <div class="timeline-number">0{index + 1}</div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-padding {
    padding: 15rem 0;
  }

  .bio-hero {
    height: 90vh;
    position: relative;
    display: flex;
    align-items: center;
    background: #000;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: url('https://images.unsplash.com/photo-1492691527719-9d1e07e534b4?auto=format&fit=crop&q=80&w=2000') no-repeat center/cover;
    opacity: 0.5;
    transform: scale(1.05);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, 
      rgba(0,0,0,0.8) 0%, 
      transparent 40%, 
      transparent 60%, 
      rgba(0,0,0,1) 100%
    );
  }

  .hero-container {
    position: relative;
    z-index: 2;
  }

  .hero-tag {
    font-family: var(--font-alt);
    font-size: 0.8rem;
    letter-spacing: 0.8em;
    color: rgba(255,255,255,0.5);
    display: block;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 15vw, 12rem);
    line-height: 0.85;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .hero-line {
    width: 20%;
    height: 1px;
    background: white;
    margin-top: 4rem;
    opacity: 0.3;
  }

  /* Intro Section */
  .intro-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 10rem;
    align-items: center;
  }

  .intro-image-wrap {
    position: relative;
  }

  .intro-image {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    clip-path: polygon(0 0, 100% 0, 100% 90%, 90% 100%, 0 100%);
  }

  .intro-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.2) contrast(1.1);
  }

  .frame-decoration {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 100px;
    height: 100px;
    border-top: 1px solid rgba(255,255,255,0.2);
    border-right: 1px solid rgba(255,255,255,0.2);
  }

  .section-label {
    font-family: var(--font-alt);
    font-size: 0.7rem;
    letter-spacing: 1em;
    color: rgba(255,255,255,0.3);
    margin-bottom: 3rem;
  }

  .intro-p p {
    font-family: var(--font-main);
    font-size: 1.2rem;
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 2rem;
    color: rgba(255,255,255,0.8);
  }

  /* Timeline */
  .timeline-header {
    margin-bottom: 12rem;
    text-align: center;
  }

  .timeline-title-main {
    font-family: var(--font-display);
    font-size: 5rem;
    letter-spacing: 0.2em;
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  .timeline-subtitle {
    font-family: var(--font-alt);
    font-size: 0.7rem;
    letter-spacing: 0.8em;
    color: rgba(255,255,255,0.4);
  }

  .timeline-grid {
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
    padding-left: 10%;
  }

  .timeline-line {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, 
      transparent, 
      rgba(255,255,255,0.2) 10%, 
      rgba(255,255,255,0.2) 90%, 
      transparent
    );
  }

  .timeline-entry {
    position: relative;
    margin-bottom: 10rem;
    padding-left: 5rem;
  }

  .timeline-dot {
    position: absolute;
    left: -4px;
    top: 0.5rem;
    width: 9px;
    height: 9px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 0 15px white;
  }

  .timeline-item-header {
    margin-bottom: 2rem;
  }

  .date {
    font-family: var(--font-alt);
    font-size: 0.75rem;
    letter-spacing: 0.4em;
    color: rgba(255,255,255,0.4);
    display: block;
    margin-bottom: 1rem;
  }

  .title {
    font-family: var(--font-display);
    font-size: 3rem;
    letter-spacing: 0.05em;
    line-height: 1;
    color: #fff;
  }

  .body p {
    font-family: var(--font-main);
    font-size: 1.1rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.6);
    max-width: 700px;
    font-weight: 300;
  }

  .timeline-number {
    position: absolute;
    right: 0;
    top: 0;
    font-family: var(--font-display);
    font-size: 6rem;
    opacity: 0.03;
    pointer-events: none;
    line-height: 1;
  }

  @media (max-width: 1024px) {
    .intro-grid {
      grid-template-columns: 1fr;
      gap: 5rem;
    }
    .timeline-grid { padding-left: 0; }
  }

  @media (max-width: 768px) {
    .section-padding { padding: 8rem 0; }
    .hero-title { font-size: 4.5rem; }
    .timeline-title-main { font-size: 3rem; }
    .title { font-size: 2.22rem; }
    .timeline-entry { padding-left: 2rem; }
  }
</style>
