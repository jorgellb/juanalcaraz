---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const filmography = await getCollection('filmography');
const sortedFilmography = filmography.sort((a, b) => b.data.year - a.data.year);

const pageTitle = 'Filmografía y Biografía - Juan Alcaraz | Cineasta';
const pageDescription = 'Descubre la biografía y filmografía completa de Juan Alcaraz, cineasta y director murciano creador de proyectos como Bar Paco, Embarazado y He pescado.';

// Datos estructurados: página de perfil del cineasta
const profilePageLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  url: new URL('/biofilmografia', Astro.site).href,
  name: pageTitle,
  description: pageDescription,
  mainEntity: { '@id': 'https://juanalcaraz.es/#person' },
};
---

<Layout title={pageTitle} description={pageDescription} jsonLd={profilePageLd}>
  <section class="bio-hero">
    <div class="container">
      <div class="hero-content">
        <div class="eh-top magic-reveal">
          <span class="eh-index">02</span>
          <span class="eh-rule"></span>
          <span class="eh-eyebrow">Trayectoria</span>
        </div>
        <h1 class="hero-title magic-reveal">FILMOGRAFÍA</h1>
        <p class="eh-accent magic-reveal">About &amp; Filmography</p>
      </div>
    </div>
  </section>

  <section class="bio-intro section-padding">
    <div class="container narrow">
      <div class="intro-grid">
        <div class="intro-image-wrap magic-reveal">
          <div class="intro-image">
            <img src="/biofilmografia.jpg" alt="Juan Alcaraz - Director de Cine y Productor" />
          </div>
        </div>
        <div class="intro-text-wrap">
          <h2 class="section-label magic-reveal">BIO</h2>
          <div class="intro-p magic-reveal" style="transition-delay: 0.2s">
            <p>Juan Alcaraz (Murcia, 1994) es un cineasta formado en Bellas Artes por la Universidad de Murcia, con un Máster en Dirección Cinematográfica por Nucine y formación complementaria en la ECAM.</p>
            <p>En 2020 funda la productora Oliva Films, desde la que desarrolla proyectos como Embarazado y He pescado, este último con más de 25 selecciones y 6 premios, entre ellos el de Mejor Montaje en el Festival de Cine de Comedia de Tarazona.</p>
            <p>Además de dirigir todo tipo de proyectos, ha trabajado en cortometrajes, series y largometrajes como primer y segundo ayudante de dirección. Compagina su actividad como cineasta con la docencia en Dirección y Producción Cinematográfica en ESCIMOSE (Escuela de Cine de Molina de Segura) y en ESI (Escuela Superior Internacional de Diseño).</p>
            <p>En 2026 estrena Bar Paco, su cortometraje más personal hasta la fecha. Actualmente, se encuentra desarrollando su primer largometraje.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bio-timeline section-padding">
    <div class="container">
      <div class="filmography-timeline">
        {sortedFilmography.map((yearGroup) => (
          <div class="year-block magic-reveal">
            <div class="year-header">
              <span class="year-label">
                <svg class="year-ghost" viewBox="0 0 400 140" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
                  <text x="0" y="112">{yearGroup.data.year}</text>
                </svg>
                {yearGroup.data.year}
              </span>
              <span class="year-line"></span>
            </div>

            <div class="projects-container">
              {yearGroup.data.items.map((item) => (
                <div class="timeline-film-item">
                  <div class="film-info">
                    <h4 class="film-title">{item.title}</h4>
                    <span class="film-category">{item.category}</span>
                  </div>
                  <div class="film-roles">
                    <p>{item.roles}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-padding {
    padding: 8rem 0;
  }

  .bio-intro {
    padding-top: 2rem;
    padding-bottom: 3rem;
  }

  .bio-timeline {
    padding-top: 4rem;
  }

  .bio-hero {
    padding: 15rem 0 5rem;
    background: #000;
  }

  .hero-tag {
    font-family: var(--font-alt);
    font-size: 0.8rem;
    letter-spacing: 0.8em;
    color: rgba(255,255,255,0.5);
    display: block;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 15vw, 10rem);
    line-height: 0.8;
    margin: 0;
    letter-spacing: 0.05em;
    /* Letras huecas (solo contorno) */
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255,255,255,0.9);
  }

  .hero-line {
    width: 60px;
    height: 1px;
    background: white;
    margin-top: 4rem;
    opacity: 0.3;
  }

  /* Intro Section */
  .intro-grid {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 2.5rem;
    align-items: stretch;
  }

  .intro-image-wrap {
    position: relative;
    max-width: 820px;
  }

  .intro-image {
    position: relative;
    height: 100%;
    min-height: 100%;
    overflow: hidden;
  }

  .intro-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.2) contrast(1.1);
    /* Bordes difuminados en los 4 lados para que no se note el corte */
    -webkit-mask-image:
      linear-gradient(to right, transparent 0%, #000 12%, #000 88%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, #000 10%, #000 90%, transparent 100%);
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(to right, transparent 0%, #000 12%, #000 88%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, #000 10%, #000 90%, transparent 100%);
    mask-composite: intersect;
  }

  .section-label {
    font-family: var(--font-alt);
    font-size: 0.7rem;
    letter-spacing: 1em;
    color: rgba(255,255,255,0.3);
    margin-bottom: 3rem;
  }

  .intro-p p {
    font-family: var(--font-main);
    font-size: 1.15rem;
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 2.5rem;
    color: rgba(255,255,255,0.85);
  }

  /* Timeline */
  .filmography-timeline {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
  }

  .year-block {
    position: relative;
    margin-bottom: 6rem;
  }

  .year-header {
    position: relative;
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding: 1.5rem 0;
    margin-bottom: 2.5rem;
    z-index: 2;
    overflow: hidden;
  }

  .year-label {
    position: relative;
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: 0.04em;
    margin: 0;
    background: linear-gradient(180deg, #ffffff 0%, rgba(255,255,255,0.4) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Numero fantasma gigante con contorno punteado (SVG) */
  .year-ghost {
    position: absolute;
    left: -1.5rem;
    top: 50%;
    transform: translateY(-50%);
    width: clamp(24rem, 58vw, 46rem);
    height: auto;
    overflow: visible;
    z-index: -1;
    pointer-events: none;
  }

  .year-ghost text {
    font-family: var(--font-display);
    font-size: 120px;
    letter-spacing: 6px;
    fill: none;
    stroke: rgba(255, 255, 255, 0.22);
    stroke-width: 1.1;
    stroke-dasharray: 1 6;
    stroke-linecap: round;
  }

  .year-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right,
      rgba(255,255,255,0.4) 0%,
      rgba(255,255,255,0.06) 55%,
      transparent 100%
    );
  }

  .projects-container {
    padding-left: 8rem;
    position: relative;
  }

  .projects-container::before {
    content: '';
    position: absolute;
    left: 3.5rem;
    top: -2.5rem;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom,
      rgba(255,255,255,0.28) 0%,
      rgba(255,255,255,0.06) 55%,
      transparent 100%
    );
  }

  .timeline-film-item {
    display: grid;
    grid-template-columns: 1.4fr 1.6fr;
    gap: 4rem;
    padding: 2rem;
    border-radius: 10px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }

  .timeline-film-item::before {
    content: '';
    position: absolute;
    left: calc(-4.5rem - 4px);
    top: 2.6rem;
    width: 9px;
    height: 9px;
    background: #fff;
    border-radius: 50%;
    opacity: 0.45;
    box-shadow: 0 0 0 4px rgba(255,255,255,0.05), 0 0 12px rgba(255,255,255,0.35);
    z-index: 3;
    transition: all 0.4s ease;
  }

  .timeline-film-item:hover {
    background: linear-gradient(to right, rgba(255,255,255,0.05), transparent 80%);
    transform: translateX(10px);
    border-bottom-color: rgba(255,255,255,0.12);
  }

  .timeline-film-item:hover::before {
    opacity: 1;
    /* Contrarresta el translateX del item para que el punto NO se desplace, solo se ilumine */
    transform: translateX(-10px) scale(1.4);
    box-shadow: 0 0 0 5px rgba(255,255,255,0.08), 0 0 20px rgba(255,255,255,0.7);
  }

  .film-info {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .film-title {
    font-family: var(--font-main);
    font-size: 1rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.92);
    margin: 0;
    line-height: 1.2;
    text-transform: uppercase;
    transition: color 0.4s ease;
  }

  .timeline-film-item:hover .film-title {
    color: #fff;
  }

  .film-category {
    font-family: var(--font-alt);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.2);
    text-transform: uppercase;
  }

  .film-roles {
    font-family: var(--font-main);
    font-size: 0.8rem;
    font-weight: 200;
    line-height: 1.6;
    color: rgba(255,255,255,0.3);
    display: flex;
    align-items: center;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .intro-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .intro-image-wrap { margin: 0 auto; }
    .intro-image { aspect-ratio: 4/5; height: auto; min-height: 0; }
    .projects-container { padding-left: 4.5rem; }
    .projects-container::before { left: 1.5rem; }
    .timeline-film-item::before { left: calc(-3rem - 4px); }
  }

  @media (max-width: 768px) {
    .section-padding { padding: 4rem 0; }
    .bio-hero { padding-top: 10rem; }
    .hero-title { font-size: 4rem; }
    .projects-container { padding-left: 3rem; }
    .projects-container::before { left: 1rem; }
    .timeline-film-item {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 1.5rem 1rem;
    }
    .timeline-film-item::before {
      top: 2rem;
      left: calc(-2rem - 4px);
    }
    .film-roles { font-size: 0.75rem; }
  }
</style>
