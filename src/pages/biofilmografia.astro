---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const filmography = await getCollection('filmography');
const sortedFilmography = filmography.sort((a, b) => b.data.year - a.data.year);

const pageTitle = 'Filmografía y Biografía - Juan Alcaraz | Cineasta';
const pageDescription = 'Descubre la biografía y filmografía completa de Juan Alcaraz, cineasta y director murciano creador de proyectos como Bar Paco, Embarazado y He pescado.';
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="bio-hero">
    <div class="hero-bg">
      <div class="hero-overlay"></div>
      <div class="hero-flare"></div>
    </div>
    <div class="container hero-container">
      <div class="hero-content">
        <span class="hero-tag magic-reveal">FILMOGRAPHY</span>
        <h1 class="hero-title magic-reveal" style="transition-delay: 0.2s">FILMOGRAFÍA</h1>
        <div class="hero-line magic-reveal" style="transition-delay: 0.4s"></div>
      </div>
    </div>
  </section>

  <section class="bio-intro section-padding">
    <div class="container narrow">
      <div class="intro-grid">
        <div class="intro-image-wrap magic-reveal">
          <div class="intro-image">
            <img src="/filmografia-2ra-foto.jpg" alt="Juan Alcaraz - Director de Cine y Productor" />
            <div class="image-overlay"></div>
          </div>
          <div class="frame-decoration"></div>
        </div>
        <div class="intro-text-wrap">
          <h2 class="section-label magic-reveal">BIO</h2>
          <div class="intro-p magic-reveal" style="transition-delay: 0.2s">
            <p>Juan Alcaraz (Murcia, 1994) es un cineasta formado en Bellas Artes por la Universidad de Murcia, con un Máster en Dirección Cinematográfica por Nucine y formación complementaria en la ECAM.</p>
            <p>En 2020 funda la productora Oliva Films, desde la que desarrolla proyectos como Embarazado y He pescado, este último con más de 25 selecciones y 6 premios, entre ellos el de Mejor Montaje en el Festival de Cine de Comedia de Tarazona.</p>
            <p>Además de dirigir todo tipo de proyectos, ha trabajado en cortometrajes, series y largometrajes como primer y segundo ayudante de dirección. Compagina su actividad como cineasta con la docencia en Dirección y Producción Cinematográfica en ESCIMOSE (Escuela de Cine de Molina de Segura) y en ESI (Escuela Superior Internacional de Diseño).</p>
            <p>En 2026 estrena Bar Paco, su cortometraje más personal hasta la fecha. Actualmente, se encuentra desarrollando su primer largometraje.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bio-timeline section-padding">
    <div class="container">
      <div class="filmography-timeline">
        {sortedFilmography.map((yearGroup, yearIndex) => (
          <div class="year-block magic-reveal" style={`transition-delay: ${yearIndex * 0.1}s`}>
            <div class="year-header">
              <div class="year-label">{yearGroup.data.year}</div>
            </div>
            
            <div class="projects-container">
              {yearGroup.data.items.map((item) => (
                <div class="timeline-film-item">
                  <div class="film-info">
                    <h4 class="film-title">{item.title}</h4>
                    <span class="film-category">{item.category}</span>
                  </div>
                  <div class="film-roles">
                    <p>{item.roles}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-padding {
    padding: 8rem 0;
  }

  .bio-hero {
    height: 70vh;
    position: relative;
    display: flex;
    align-items: center;
    background: #000;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: url('/filmografia-1ra-foto.jpg') no-repeat center/cover;
    opacity: 0.5;
    transform: scale(1.05);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, 
      rgba(0,0,0,0.8) 0%, 
      transparent 40%, 
      transparent 60%, 
      rgba(0,0,0,1) 100%
    );
  }

  .hero-container {
    position: relative;
    z-index: 2;
  }

  .hero-tag {
    font-family: var(--font-alt);
    font-size: 0.8rem;
    letter-spacing: 0.8em;
    color: rgba(255,255,255,0.5);
    display: block;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 15vw, 12rem);
    line-height: 0.85;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .hero-line {
    width: 60px;
    height: 1px;
    background: white;
    margin-top: 4rem;
    opacity: 0.3;
  }

  /* Intro Section */
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 6rem;
    align-items: start;
  }

  .intro-image-wrap {
    position: relative;
    max-width: 450px;
  }

  .intro-image {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    clip-path: polygon(0 0, 100% 0, 100% 90%, 90% 100%, 0 100%);
  }

  .intro-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.2) contrast(1.1);
  }

  .frame-decoration {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 100px;
    height: 100px;
    border-top: 1px solid rgba(255,255,255,0.2);
    border-right: 1px solid rgba(255,255,255,0.2);
    z-index: 1;
  }

  .section-label {
    font-family: var(--font-alt);
    font-size: 0.7rem;
    letter-spacing: 1em;
    color: rgba(255,255,255,0.3);
    margin-bottom: 3rem;
  }

  .intro-p p {
    font-family: var(--font-main);
    font-size: 1.15rem;
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 2.5rem;
    color: rgba(255,255,255,0.85);
  }

  /* Timeline */
  .filmography-timeline {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
  }

  .year-block {
    position: relative;
    margin-bottom: 15rem;
  }

  .year-header {
    position: relative;
    padding: 2rem 0;
    text-align: center;
    z-index: 2;
    margin-bottom: 4rem;
  }

  .year-label {
    font-family: var(--font-magic);
    font-size: clamp(2.5rem, 8vw, 3.5rem);
    font-style: italic;
    font-weight: 200;
    line-height: 1;
    color: #fff;
    letter-spacing: 0.1em;
    margin: 0;
    opacity: 0.85;
  }

  .projects-container {
    padding-left: 10rem;
    position: relative;
  }

  .projects-container::before {
    content: '';
    position: absolute;
    left: 4.5rem;
    top: -3rem;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, 
      rgba(255,255,255,0.1) 0%, 
      rgba(255,255,255,0.02) 100%
    );
  }

  .timeline-film-item {
    display: grid;
    grid-template-columns: 1.4fr 1.6fr;
    gap: 4rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }

  .timeline-film-item::before {
    content: '';
    position: absolute;
    left: -5.625rem; /* 4.5rem - 10rem - half dot (2px) */
    top: 3.1rem;
    width: 4px;
    height: 4px;
    background: rgba(255,255,255,0.2);
    border-radius: 50%;
    z-index: 3;
    transition: all 0.4s ease;
  }

  .timeline-film-item:hover {
    padding-left: 2rem;
    border-bottom-color: rgba(255,255,255,0.1);
  }

  .timeline-film-item:hover::before {
    background: #fff;
    box-shadow: 0 0 10px #fff;
    transform: scale(1.5);
  }

  .film-info {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .film-title {
    font-family: var(--font-main);
    font-size: 1rem;
    font-weight: 200;
    letter-spacing: 0.1em;
    color: #fff;
    margin: 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .film-category {
    font-family: var(--font-alt);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.2);
    text-transform: uppercase;
  }

  .film-roles {
    font-family: var(--font-main);
    font-size: 0.8rem;
    font-weight: 200;
    line-height: 1.6;
    color: rgba(255,255,255,0.3);
    display: flex;
    align-items: center;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .intro-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .intro-image-wrap { margin: 0 auto; }
    .projects-container { padding-left: 5rem; }
    .projects-container::before { left: 1rem; }
    .timeline-film-item::before { left: -4.125rem; }
  }

  @media (max-width: 768px) {
    .section-padding { padding: 4rem 0; }
    .hero-title { font-size: 3.5rem; }
    .projects-container { padding-left: 3rem; }
    .timeline-film-item {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 2rem 0;
    }
    .timeline-film-item::before { 
      top: 2.5rem; 
      left: -2.125rem; 
    }
    .film-roles { font-size: 0.75rem; }
  }
</style>
