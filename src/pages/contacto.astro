---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Contacto - Juan Alcaraz | Cineasta';
const pageDescription = 'Contacta con Juan Alcaraz, cineasta y director para nuevos proyectos audiovisuales. Telf: +34 663 384 218 | Email: juanalcarazcine@gmail.com';

// Datos estructurados: página de contacto vinculada al perfil del cineasta
const contactPageLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  url: new URL('/contacto', Astro.site).href,
  name: pageTitle,
  description: pageDescription,
  mainEntity: { '@id': 'https://juanalcaraz.es/#person' },
};
---

<Layout title={pageTitle} description={pageDescription} jsonLd={contactPageLd}>
  <section class="contact-hero">
    <div class="container">
      <div class="hero-content">
        <div class="eh-top magic-reveal">
          <span class="eh-index">03</span>
          <span class="eh-rule"></span>
          <span class="eh-eyebrow">Hablemos</span>
        </div>
        <h1 class="hero-title magic-reveal">CONTACTO</h1>
        <p class="eh-accent magic-reveal">Let's Tell a Story</p>
      </div>
    </div>
  </section>

  <section class="contact-section">
    <div class="container">
      <div class="contact-list">
        <a href="mailto:juanalcarazcine@gmail.com" class="contact-row magic-reveal">
          <span class="cr-label">Email</span>
          <span class="cr-value">juanalcarazcine@gmail.com</span>
          <span class="cr-arrow" aria-hidden="true">↗</span>
        </a>
        <a href="tel:+34663384218" class="contact-row magic-reveal">
          <span class="cr-label">Teléfono</span>
          <span class="cr-value">+34 663 384 218</span>
          <span class="cr-arrow" aria-hidden="true">↗</span>
        </a>
        <a href="https://instagram.com/juanalcarazcine" target="_blank" rel="noopener" class="contact-row magic-reveal">
          <span class="cr-label">Instagram</span>
          <span class="cr-value">@juanalcarazcine</span>
          <span class="cr-arrow" aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-hero {
    padding: 15rem 0 5rem;
    background: #000;
  }

  .hero-tag {
    font-family: var(--font-alt);
    font-size: 0.8rem;
    letter-spacing: 0.8em;
    color: rgba(255,255,255,0.5);
    display: block;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 15vw, 10rem);
    line-height: 0.8;
    margin: 0;
    letter-spacing: 0.05em;
    color: #fff;
  }

  .hero-line {
    width: 60px;
    height: 1px;
    background: white;
    margin-top: 4rem;
    opacity: 0.3;
  }

  /* Contact Section */
  .contact-section {
    padding: 2rem 0 12rem;
    background: #000;
  }

  /* ===== Lista de contacto (elegante) ===== */
  .contact-list {
    max-width: 980px;
    margin: 0 auto;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .contact-row {
    display: grid;
    grid-template-columns: 190px 1fr auto;
    align-items: center;
    gap: 2rem;
    padding: 2.6rem 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
    position: relative;
    transition: padding 0.55s cubic-bezier(0.16, 1, 0.3, 1),
                background 0.55s ease;
  }

  .contact-row:hover {
    padding-left: 2rem;
    background: linear-gradient(to right, rgba(255, 255, 255, 0.04), transparent 70%);
  }

  .cr-label {
    font-family: var(--font-alt);
    font-size: 0.62rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    transition: color 0.4s ease;
  }
  .contact-row:hover .cr-label { color: rgba(255, 255, 255, 0.6); }

  .cr-value {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.6rem);
    letter-spacing: 0.04em;
    line-height: 1;
    color: rgba(255, 255, 255, 0.9);
    transition: color 0.4s ease;
  }
  .contact-row:hover .cr-value { color: #fff; }

  .cr-arrow {
    font-family: var(--font-alt);
    font-size: 1.4rem;
    color: rgba(255, 255, 255, 0.3);
    opacity: 0;
    transform: translate(-8px, 8px);
    transition: all 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .contact-row:hover .cr-arrow {
    opacity: 1;
    transform: translate(0, 0);
    color: #fff;
  }

  @media (max-width: 1024px) {
    .contact-section { padding: 1.5rem 0 8rem; }
  }

  @media (max-width: 768px) {
    .contact-section { padding: 1rem 0 6rem; }
    .contact-hero { padding-top: 10rem; }
    .hero-tag { font-size: 0.7rem; letter-spacing: 0.5em; }
    .hero-title { font-size: 4rem; }
    .contact-row {
      grid-template-columns: 1fr auto;
      gap: 0.4rem 1rem;
      padding: 1.8rem 0.25rem;
    }
    .cr-label { grid-column: 1 / -1; }
    .cr-value { word-break: break-word; }
    .contact-row:hover { padding-left: 0.75rem; }
  }
</style>
