---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Contacto - Juan Alcaraz | Cineasta';
const pageDescription = 'Contacta con Juan Alcaraz, cineasta y director para nuevos proyectos audiovisuales. Telf: +34 663 384 218 | Email: juanalcarazcine@gmail.com';
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="contact-hero">
    <div class="hero-bg">
      <div class="hero-overlay"></div>
      <div class="hero-flare"></div>
    </div>
    <div class="container hero-container">
      <div class="hero-content">
        <span class="hero-tag magic-reveal">WRITE THE FUTURE</span>
        <h1 class="hero-title magic-reveal" style="transition-delay: 0.2s">CONTACTO</h1>
        <div class="hero-line magic-reveal" style="transition-delay: 0.4s"></div>
      </div>
    </div>
  </section>

  <section class="contact-section">
    <div class="container">
      <div class="contact-center-wrap">
        <div class="info-container">
          <div class="info-block magic-reveal" style="transition-delay: 0.6s">
            <h3 class="info-label">EMAIL DIRECTO</h3>
            <a href="mailto:juanalcarazcine@gmail.com" class="info-link">JUANALCARAZCINE@GMAIL.COM</a>
          </div>
          
          <div class="info-block magic-reveal" style="transition-delay: 0.8s">
            <h3 class="info-label">TELÉFONO</h3>
            <a href="tel:+34663384218" class="info-link">+34 663 384 218</a>
          </div>

          <div class="info-block magic-reveal" style="transition-delay: 1s">
            <h3 class="info-label">SOCIAL</h3>
            <div class="social-links">
              <a href="https://instagram.com/juanalcarazcine" target="_blank" class="info-link">INSTAGRAM</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-hero {
    height: 70vh;
    position: relative;
    display: flex;
    align-items: center;
    background: #000;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: url('/contacto.jpg') no-repeat center/cover;
    opacity: 0.5;
    transform: scale(1.05);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, 
      rgba(0,0,0,0.8) 0%, 
      transparent 40%, 
      transparent 60%, 
      rgba(0,0,0,1) 100%
    );
  }

  .hero-container {
    position: relative;
    z-index: 2;
  }

  .hero-tag {
    font-family: var(--font-alt);
    font-size: 0.8rem;
    letter-spacing: 0.8em;
    color: rgba(255,255,255,0.5);
    display: block;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 15vw, 10rem);
    line-height: 1;
    margin: 0;
    letter-spacing: 0.1em;
  }

  .hero-line {
    width: 60px;
    height: 1px;
    background: white;
    margin-top: 4rem;
    opacity: 0.3;
  }

  /* Contact Section */
  .contact-section {
    padding: 12rem 0;
    background: #000;
  }

  .contact-center-wrap {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    width: 100%;
  }

  .info-container {
    display: flex;
    flex-direction: column;
    gap: 6rem;
    align-items: center; /* Center children */
    width: 100%;
  }

  .info-block {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    width: 100%;
  }

  .info-label {
    font-family: var(--font-alt);
    font-size: 0.7rem;
    letter-spacing: 0.5em;
    color: rgba(255,255,255,0.25);
    margin: 0;
    text-align: center;
  }

  .info-link {
    font-family: var(--font-main);
    font-size: clamp(1.2rem, 4vw, 2.2rem);
    color: #fff;
    text-decoration: none;
    transition: all 0.4s ease;
    font-weight: 300;
    letter-spacing: 0.05em;
    display: inline-block;
    text-align: center;
  }

  .info-link:hover {
    opacity: 0.6;
    letter-spacing: 0.1em;
  }

  .social-links {
    display: flex;
    gap: 3rem;
    justify-content: center;
    width: 100%;
  }

  @media (max-width: 1024px) {
    .contact-section { padding: 8rem 0; }
    .info-container { gap: 4rem; }
    .hero-title { font-size: 5rem; }
  }

  @media (max-width: 768px) {
    .contact-section { padding: 6rem 0; }
    .hero-tag { font-size: 0.7rem; letter-spacing: 0.5em; }
    .hero-title { font-size: 3.5rem; }
    .info-link { 
      font-size: 1.1rem; /* Smaller to avoid overflow */
      word-break: break-all;
      max-width: 90vw;
    }
    .social-links {
      gap: 2rem;
    }
  }
</style>
