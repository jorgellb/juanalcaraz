---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Contacto - Juan Alcaraz | Cineasta';
const pageDescription = 'Contacta con Juan Alcaraz, cineasta y director para nuevos proyectos audiovisuales. Telf: +34 663 384 218 | Email: juanalcarazcine@gmail.com';
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="contact-hero">
    <div class="container">
      <div class="hero-content">
        <div class="eh-top magic-reveal">
          <span class="eh-index">03</span>
          <span class="eh-rule"></span>
          <span class="eh-eyebrow">Hablemos</span>
        </div>
        <h1 class="hero-title magic-reveal">CONTACTO</h1>
        <p class="eh-accent magic-reveal">Let's Tell a Story</p>
      </div>
    </div>
  </section>

  <section class="contact-section">
    <div class="container">
      <div class="contact-center-wrap">
        <div class="info-container">
          <div class="info-block magic-reveal">
            <h3 class="info-label">EMAIL DIRECTO</h3>
            <a href="mailto:juanalcarazcine@gmail.com" class="info-link">JUANALCARAZCINE@GMAIL.COM</a>
          </div>

          <div class="info-block magic-reveal">
            <h3 class="info-label">TELÉFONO</h3>
            <a href="tel:+34663384218" class="info-link">+34 663 384 218</a>
          </div>

          <div class="info-block magic-reveal">
            <h3 class="info-label">SOCIAL</h3>
            <div class="social-links">
              <a href="https://instagram.com/juanalcarazcine" target="_blank" class="info-link">INSTAGRAM</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-hero {
    padding: 15rem 0 5rem;
    background: #000;
  }

  .hero-tag {
    font-family: var(--font-alt);
    font-size: 0.8rem;
    letter-spacing: 0.8em;
    color: rgba(255,255,255,0.5);
    display: block;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 15vw, 10rem);
    line-height: 1;
    margin: 0;
    letter-spacing: 0.1em;
    /* Letras huecas (solo contorno) */
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255,255,255,0.9);
  }

  .hero-line {
    width: 60px;
    height: 1px;
    background: white;
    margin-top: 4rem;
    opacity: 0.3;
  }

  /* Contact Section */
  .contact-section {
    padding: 2rem 0 12rem;
    background: #000;
  }

  .contact-center-wrap {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    width: 100%;
  }

  .info-container {
    display: flex;
    flex-direction: column;
    gap: 6rem;
    align-items: center; /* Center children */
    width: 100%;
  }

  .info-block {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    width: 100%;
  }

  .info-label {
    font-family: var(--font-alt);
    font-size: 0.7rem;
    letter-spacing: 0.5em;
    color: rgba(255,255,255,0.25);
    margin: 0;
    text-align: center;
  }

  .info-link {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 5vw, 2.8rem);
    color: #fff;
    text-decoration: none;
    transition: all 0.4s ease;
    font-weight: 400;
    letter-spacing: 0.08em;
    display: inline-block;
    text-align: center;
  }

  .info-link:hover {
    opacity: 0.6;
    letter-spacing: 0.1em;
  }

  .social-links {
    display: flex;
    gap: 3rem;
    justify-content: center;
    width: 100%;
  }

  @media (max-width: 1024px) {
    .contact-section { padding: 1.5rem 0 8rem; }
    .info-container { gap: 4rem; }
    .hero-title { font-size: 5rem; }
  }

  @media (max-width: 768px) {
    .contact-section { padding: 1rem 0 6rem; }
    .hero-tag { font-size: 0.7rem; letter-spacing: 0.5em; }
    .hero-title { font-size: 3.5rem; }
    .info-link { 
      font-size: 1.1rem; /* Smaller to avoid overflow */
      word-break: break-all;
      max-width: 90vw;
    }
    .social-links {
      gap: 2rem;
    }
  }
</style>
