---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Contacto - Juan Alcaraz | Cineasta';
const pageDescription = 'Contacta con Juan Alcaraz, cineasta y director para nuevos proyectos audiovisuales. Telf: +34 663 384 218 | Email: juanalcarazcine@gmail.com';
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="contact-hero">
    <div class="container">
      <div class="hero-content">
        <div class="eh-top magic-reveal">
          <span class="eh-index">03</span>
          <span class="eh-rule"></span>
          <span class="eh-eyebrow">Hablemos</span>
        </div>
        <h1 class="hero-title magic-reveal">CONTACTO</h1>
        <p class="eh-accent magic-reveal">Let's Tell a Story</p>
      </div>
    </div>
  </section>

  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <form class="contact-form magic-reveal" id="contact-form" novalidate>
          <div class="cf-field">
            <input type="text" id="cf-name" name="name" required placeholder=" " autocomplete="name" />
            <label for="cf-name">Nombre</label>
            <span class="cf-line"></span>
          </div>
          <div class="cf-field">
            <input type="email" id="cf-email" name="email" required placeholder=" " autocomplete="email" />
            <label for="cf-email">Email</label>
            <span class="cf-line"></span>
          </div>
          <div class="cf-field">
            <textarea id="cf-message" name="message" required placeholder=" " rows="4"></textarea>
            <label for="cf-message">Cuéntame tu proyecto</label>
            <span class="cf-line"></span>
          </div>
          <div class="cf-actions">
            <button type="submit" class="cf-btn cf-btn-send">Enviar email</button>
            <button type="button" class="cf-btn cf-btn-wa" id="cf-wa">WhatsApp</button>
          </div>
          <p class="cf-status" id="cf-status" role="status" aria-live="polite"></p>
        </form>

        <aside class="contact-direct magic-reveal">
          <div class="cd-block">
            <h3 class="cd-label">Email</h3>
            <a href="mailto:juanalcarazcine@gmail.com" class="cd-link">juanalcarazcine@gmail.com</a>
          </div>
          <div class="cd-block">
            <h3 class="cd-label">Teléfono</h3>
            <a href="tel:+34663384218" class="cd-link">+34 663 384 218</a>
          </div>
          <div class="cd-block">
            <h3 class="cd-label">Social</h3>
            <a href="https://instagram.com/juanalcarazcine" target="_blank" rel="noopener" class="cd-link">Instagram</a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<script>
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form || form.dataset.init) return;
    form.dataset.init = '1';
    const status = document.getElementById('cf-status');
    const waBtn = document.getElementById('cf-wa');
    const val = (id: string) => ((document.getElementById(id) as HTMLInputElement | null)?.value || '').trim();
    const setStatus = (msg: string, cls = '') => {
      if (status) { status.textContent = msg; status.className = 'cf-status' + (cls ? ' ' + cls : ''); }
    };

    waBtn?.addEventListener('click', () => {
      const name = val('cf-name'), email = val('cf-email'), msg = val('cf-message');
      const text = `Hola Juan, soy ${name || ''}${email ? ' (' + email + ')' : ''}.\n\n${msg}`;
      window.open('https://wa.me/34663384218?text=' + encodeURIComponent(text), '_blank');
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = val('cf-name'), email = val('cf-email'), message = val('cf-message');
      if (!name || !email || !message) { setStatus('Completa todos los campos.', 'err'); return; }
      const btn = form.querySelector('.cf-btn-send') as HTMLButtonElement;
      btn.disabled = true;
      setStatus('Enviando…');
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, message }),
        });
        if (res.ok) {
          setStatus('¡Mensaje enviado! Te responderé pronto.', 'ok');
          form.reset();
        } else {
          const d = await res.json().catch(() => ({} as any));
          setStatus(d.error || 'No se pudo enviar. Prueba por WhatsApp.', 'err');
        }
      } catch (_) {
        setStatus('Error de conexión. Prueba por WhatsApp.', 'err');
      } finally {
        btn.disabled = false;
      }
    });
  }
  document.addEventListener('astro:page-load', initContactForm);
  initContactForm();
</script>

<style>
  .contact-hero {
    padding: 15rem 0 5rem;
    background: #000;
  }

  .hero-tag {
    font-family: var(--font-alt);
    font-size: 0.8rem;
    letter-spacing: 0.8em;
    color: rgba(255,255,255,0.5);
    display: block;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 15vw, 10rem);
    line-height: 0.8;
    margin: 0;
    letter-spacing: 0.05em;
    /* Letras huecas (solo contorno) */
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255,255,255,0.9);
  }

  .hero-line {
    width: 60px;
    height: 1px;
    background: white;
    margin-top: 4rem;
    opacity: 0.3;
  }

  /* Contact Section */
  .contact-section {
    padding: 2rem 0 12rem;
    background: #000;
  }

  /* ===== Formulario de contacto (minimal/cine) ===== */
  .contact-grid {
    display: grid;
    grid-template-columns: 1.45fr 1fr;
    gap: 6rem;
    max-width: 1100px;
    margin: 0 auto;
    align-items: start;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 2.8rem;
  }

  .cf-field {
    position: relative;
  }

  .cf-field input,
  .cf-field textarea {
    width: 100%;
    background: transparent;
    border: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    padding: 0.85rem 0;
    color: #fff;
    font-family: var(--font-main);
    font-size: 1.05rem;
    font-weight: 300;
    letter-spacing: 0.02em;
    outline: none;
    resize: none;
  }

  .cf-field textarea { line-height: 1.6; }

  .cf-field label {
    position: absolute;
    left: 0;
    top: 0.85rem;
    color: rgba(255, 255, 255, 0.4);
    font-family: var(--font-alt);
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    pointer-events: none;
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cf-field input:focus ~ label,
  .cf-field input:not(:placeholder-shown) ~ label,
  .cf-field textarea:focus ~ label,
  .cf-field textarea:not(:placeholder-shown) ~ label {
    top: -0.95rem;
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }

  .cf-line {
    position: absolute;
    left: 0;
    bottom: 0;
    height: 1px;
    width: 100%;
    background: #fff;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cf-field input:focus ~ .cf-line,
  .cf-field textarea:focus ~ .cf-line { transform: scaleX(1); }

  .cf-actions {
    display: flex;
    gap: 1.2rem;
    margin-top: 0.6rem;
    flex-wrap: wrap;
  }

  .cf-btn {
    font-family: var(--font-alt);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    padding: 1.1rem 2.6rem;
    cursor: pointer;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: transparent;
    color: #fff;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cf-btn-send { background: #fff; color: #000; border-color: #fff; }
  .cf-btn-send:hover { background: transparent; color: #fff; }
  .cf-btn-wa:hover { border-color: #fff; background: rgba(255, 255, 255, 0.06); }
  .cf-btn:disabled { opacity: 0.5; cursor: default; }

  .cf-status {
    font-family: var(--font-alt);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.6);
    min-height: 1.2em;
    margin: 0;
  }
  .cf-status.ok { color: #8fd6a4; }
  .cf-status.err { color: #e58a8a; }

  /* Contacto directo */
  .contact-direct {
    display: flex;
    flex-direction: column;
    gap: 2.6rem;
    padding-top: 0.4rem;
  }
  .cd-block { display: flex; flex-direction: column; gap: 0.6rem; }
  .cd-label {
    font-family: var(--font-alt);
    font-size: 0.62rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    margin: 0;
  }
  .cd-link {
    font-family: var(--font-main);
    font-size: 1.05rem;
    font-weight: 300;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.85);
    transition: color 0.3s ease;
  }
  .cd-link:hover { color: #fff; }

  @media (max-width: 1024px) {
    .contact-section { padding: 1.5rem 0 8rem; }
    .contact-grid { gap: 4rem; }
  }

  @media (max-width: 768px) {
    .contact-section { padding: 1rem 0 6rem; }
    .contact-hero { padding-top: 10rem; }
    .hero-tag { font-size: 0.7rem; letter-spacing: 0.5em; }
    .hero-title { font-size: 4rem; }
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }
    .cd-link { word-break: break-word; }
  }
</style>
