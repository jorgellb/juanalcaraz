---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const categories = ['TODOS', 'FICCIÓN', 'VIDEOCLIP', 'PUBLICIDAD', 'OTRAS PRODUCCIONES'];

const pageTitle = 'Proyectos Audiovisuales y Cortometrajes | Juan Alcaraz';
const pageDescription = 'Explora el portfolio completo de proyectos, publicidad, ficción y videoclips de Juan Alcaraz, director y cineasta.';

// Datos estructurados: lista de obras del portafolio
const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: new URL('/proyectos', Astro.site).href,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: sortedProjects.length,
    itemListElement: sortedProjects.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'CreativeWork',
        name: p.data.title,
        genre: p.data.category,
        datePublished: String(p.data.year),
        url: p.data.videoUrl,
        creator: { '@type': 'Person', name: 'Juan Alcaraz' },
        ...(p.data.thumbnail
          ? { image: new URL(p.data.thumbnail, Astro.site).href }
          : {}),
      },
    })),
  },
};
---

<Layout title={pageTitle} description={pageDescription} jsonLd={itemListLd}>
  <section class="projects-hero">
    <div class="container">
      <div class="hero-content">
        <div class="eh-top magic-reveal">
          <span class="eh-index">01</span>
          <span class="eh-rule"></span>
          <span class="eh-eyebrow">Portfolio</span>
        </div>
        <h1 class="hero-title magic-reveal">PROYECTOS</h1>
        <p class="eh-accent magic-reveal">Selected Work</p>
      </div>
    </div>
  </section>

  <section class="projects-main">
    <div class="container full-width">
      <div class="filter-wrapper magic-reveal" style="transition-delay: 0.4s">
        <div class="filter-bar">
          {categories.map((cat, index) => (
            <button
              type="button"
              class:list={['filter-btn', { active: cat === 'TODOS' }]}
              data-category={cat === 'TODOS' ? 'all' : cat}
              aria-pressed={cat === 'TODOS' ? 'true' : 'false'}
            >
              <span class="btn-num">0{index}</span>
              <span class="btn-label">{cat}</span>
            </button>
          ))}
        </div>
        
        <div class="mobile-filter">
          <label for="category-select" class="visually-hidden">Filtrar por categoría</label>
          <div class="select-wrapper">
            <select id="category-select" class="custom-select">
              {categories.map((cat) => (
                <option value={cat === 'TODOS' ? 'all' : cat}>{cat}</option>
              ))}
            </select>
            <div class="select-icon">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <div class="projects-grid-container">
        <div class="projects-grid" id="projects-grid">
          {sortedProjects.map((project) => (
            <div class="grid-item" data-category={project.data.category}>
              <ProjectCard project={project} />
            </div>
          ))}
        </div>
        <div class="no-results" id="no-results" role="status">No se han encontrado proyectos en esta categoría.</div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .projects-hero {
    padding: 15rem 0 5rem;
    background: #000;
  }

  .hero-tag {
    font-family: var(--font-alt);
    font-size: 0.7rem;
    letter-spacing: 0.8em;
    color: rgba(255,255,255,0.4);
    display: block;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 15vw, 10rem);
    line-height:0.8;
    letter-spacing: 0.05em;
    margin: 0;
    color: #fff;
  }

  .projects-main {
    background: #000;
    padding-bottom: 0;
  }

  /* Filter Bar */
  .filter-wrapper {
    margin-bottom: 8rem;
    padding: 0 5%;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 1rem;
  }

  .filter-btn {
    background: none;
    border: none;
    color: rgba(255,255,255,0.3);
    cursor: pointer;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.5rem 0;
    transition: color 0.4s ease;
    position: relative;
  }

  .filter-btn::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background: #fff;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .filter-btn:hover {
    color: rgba(255,255,255,0.6);
  }

  .filter-btn.active {
    color: #fff;
  }

  .filter-btn.active::after {
    width: 100%;
  }

  .btn-num {
    font-family: var(--font-alt);
    font-size: 0.5rem;
    opacity: 0.3;
    letter-spacing: 0.1em;
  }

  .btn-label {
    font-family: var(--font-main);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    font-weight: 300;
  }

  /* Mobile Filter */
  .mobile-filter {
    display: none;
    width: 100%;
    margin-bottom: 2rem;
  }

  .select-wrapper {
    position: relative;
    width: 100%;
    border-bottom: 1px solid rgba(255,255,255,0.2);
  }

  .custom-select {
    width: 100%;
    background: transparent;
    color: white;
    font-family: var(--font-main);
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 1rem 2rem 1rem 0;
    border: none;
    appearance: none;
    outline: none;
    cursor: pointer;
  }

  .custom-select option {
    background: #0a0a0a;
    color: white;
    padding: 1rem;
  }

  .select-icon {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: rgba(255,255,255,0.5);
  }

  /* Grid */
  .container.full-width {
    max-width: 100%;
    padding: 0;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    transition: opacity 0.4s ease;
  }

  .grid-item {
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .grid-item.hidden {
    display: none;
  }

  .no-results {
    display: none;
    text-align: center;
    padding: 10rem 0;
    font-family: var(--font-alt);
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  @media (max-width: 1200px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .projects-hero { padding-top: 10rem; }
    .hero-title { font-size: 4rem; }
    .projects-grid { grid-template-columns: 1fr; }
    
    .filter-bar { display: none; }
    .mobile-filter { display: block; }
  }
</style>

<script>
  function initFilters() {
    const btns = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.grid-item');
    const grid = document.getElementById('projects-grid');
    const noResults = document.getElementById('no-results');
    const select = document.getElementById('category-select') as HTMLSelectElement;

    function applyFilter(filter: string) {
      // Cross-fade elegante: atenúa la rejilla, intercambia y vuelve a mostrar
      if (grid) grid.style.opacity = '0';

      window.setTimeout(() => {
        let visibleCount = 0;
        items.forEach(item => {
          const cat = item.getAttribute('data-category');
          if (filter === 'all' || cat === filter) {
            item.classList.remove('hidden');
            visibleCount++;
          } else {
            item.classList.add('hidden');
          }
        });

        if (visibleCount === 0) {
          if (grid) grid.style.display = 'none';
          if (noResults) noResults.style.display = 'block';
        } else {
          if (grid) { grid.style.display = 'grid'; grid.style.opacity = '1'; }
          if (noResults) noResults.style.display = 'none';
        }

        // Trigger reveal animations
        window.dispatchEvent(new Event('scroll'));
      }, 260);
    }

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Active state
        btns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');

        const filter = btn.getAttribute('data-category');
        if(select) select.value = filter || 'all';
        applyFilter(filter || 'all');
      });
    });

    if (select) {
      select.addEventListener('change', (e) => {
        const filter = (e.target as HTMLSelectElement).value;
        
        // Sync desktop buttons
        btns.forEach(b => {
          const isActive = b.getAttribute('data-category') === filter;
          b.classList.toggle('active', isActive);
          b.setAttribute('aria-pressed', String(isActive));
        });
        
        applyFilter(filter);
      });
    }
  }

  document.addEventListener('astro:page-load', initFilters);
  initFilters();
</script>
