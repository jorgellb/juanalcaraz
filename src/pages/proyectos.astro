---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const categories = ['Todo', ...new Set(allProjects.map((p) => p.data.category))].filter(Boolean).sort();

const pageTitle = 'Proyectos - Juan Alcazar';
const pageDescription = 'Filmografía completa y proyectos audiovisuales de Juan Alcazar.';
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="projects-hero">
    <div class="container">
      <div class="hero-content">
        <span class="hero-tag magic-reveal">EL ARCHIVO</span>
        <h1 class="hero-title magic-reveal" style="transition-delay: 0.2s">PROYECTOS</h1>
      </div>
    </div>
  </section>

  <section class="projects-main">
    <div class="container full-width">
      <div class="filter-wrapper magic-reveal" style="transition-delay: 0.4s">
        <div class="filter-bar">
          {categories.map((cat, index) => (
            <button 
              class:list={['filter-btn', { active: cat === 'Todo' }]} 
              data-category={cat === 'Todo' ? 'all' : cat}
            >
              <span class="btn-num">0{index}</span>
              <span class="btn-label">{cat}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="projects-grid-container">
        <div class="projects-grid" id="projects-grid">
          {sortedProjects.map((project) => (
            <div class="grid-item" data-category={project.data.category}>
              <ProjectCard project={project} />
            </div>
          ))}
        </div>
        <div class="no-results" id="no-results">No se han encontrado proyectos en esta categoría.</div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .projects-hero {
    padding: 15rem 0 5rem;
    background: #000;
  }

  .hero-tag {
    font-family: var(--font-alt);
    font-size: 0.7rem;
    letter-spacing: 0.8em;
    color: rgba(255,255,255,0.4);
    display: block;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 15vw, 10rem);
    line-height:0.8;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .projects-main {
    background: #000;
    padding-bottom: 15rem;
  }

  /* Filter Bar */
  .filter-wrapper {
    margin-bottom: 8rem;
    padding: 0 5%;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 4rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 2rem;
  }

  .filter-btn {
    background: none;
    border: none;
    color: rgba(255,255,255,0.3);
    cursor: pointer;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 0;
    transition: color 0.4s ease;
    position: relative;
  }

  .filter-btn::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background: #fff;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .filter-btn.active {
    color: #fff;
  }

  .filter-btn.active::after {
    width: 100%;
  }

  .btn-num {
    font-family: var(--font-alt);
    font-size: 0.6rem;
    opacity: 0.5;
    margin-top: 0.2rem;
  }

  .btn-label {
    font-family: var(--font-alt);
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  /* Grid */
  .container.full-width {
    max-width: 100%;
    padding: 0 5%;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    transition: opacity 0.4s ease;
  }

  .grid-item {
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .grid-item.hidden {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    pointer-events: none;
    position: absolute;
    visibility: hidden;
  }

  .no-results {
    display: none;
    text-align: center;
    padding: 10rem 0;
    font-family: var(--font-alt);
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  @media (max-width: 1200px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .projects-hero { padding-top: 10rem; }
    .hero-title { font-size: 4rem; }
    .filter-bar { gap: 2rem; }
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  function initFilters() {
    const btns = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.grid-item');
    const grid = document.getElementById('projects-grid');
    const noResults = document.getElementById('no-results');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Active state
        btns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const filter = btn.getAttribute('data-category');
        let visibleCount = 0;

        // Filtering
        items.forEach(item => {
          const cat = item.getAttribute('data-category');
          if (filter === 'all' || cat === filter) {
            item.classList.remove('hidden');
            visibleCount++;
          } else {
            item.classList.add('hidden');
          }
        });

        // Toggle Grid/No-Results
        if (visibleCount === 0) {
          if (grid) grid.style.display = 'none';
          if (noResults) noResults.style.display = 'block';
        } else {
          if (grid) grid.style.display = 'grid';
          if (noResults) noResults.style.display = 'none';
        }

        // Trigger reveal animations
        window.dispatchEvent(new Event('scroll'));
      });
    });
  }

  document.addEventListener('astro:page-load', initFilters);
  initFilters();
</script>
