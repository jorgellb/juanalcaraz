---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const categories = ['TODOS', 'FICCIÓN', 'VIDEOCLIP', 'PUBLICIDAD', 'OTRAS PRODUCCIONES'];

const pageTitle = 'Proyectos Audiovisuales y Cortometrajes | Juan Alcaraz';
const pageDescription = 'Explora el portfolio completo de proyectos, publicidad, ficción y videoclips de Juan Alcaraz, director y cineasta.';

// Datos estructurados: lista de obras del portafolio
const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: new URL('/proyectos', Astro.site).href,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: sortedProjects.length,
    itemListElement: sortedProjects.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'CreativeWork',
        name: p.data.title,
        genre: p.data.category,
        datePublished: String(p.data.year),
        url: p.data.videoUrl,
        creator: { '@type': 'Person', name: 'Juan Alcaraz' },
        ...(p.data.thumbnail
          ? { image: new URL(p.data.thumbnail, Astro.site).href }
          : {}),
      },
    })),
  },
};
---

<Layout title={pageTitle} description={pageDescription} jsonLd={itemListLd}>
  <section class="projects-hero">
    <div class="container">
      <div class="hero-content">
        <div class="eh-top magic-reveal">
          <span class="eh-index">01</span>
          <span class="eh-rule"></span>
          <span class="eh-eyebrow">Portfolio</span>
        </div>
        <h1 class="hero-title magic-reveal">PROYECTOS</h1>
        <p class="eh-accent magic-reveal">Selected Work</p>
      </div>
    </div>
  </section>

  <section class="projects-main">
    <div class="container full-width">
      <div class="filter-wrapper magic-reveal" style="transition-delay: 0.4s">
        <div class="filter-bar">
          {categories.map((cat, index) => (
            <button 
              class:list={['filter-btn', { active: cat === 'TODOS' }]} 
              data-category={cat === 'TODOS' ? 'all' : cat}
            >
              <span class="btn-num">0{index}</span>
              <span class="btn-label">{cat}</span>
            </button>
          ))}
        </div>
        
        <div class="mobile-filter">
          <label for="category-select" class="sr-only">Filtrar por categoría</label>
          <div class="select-wrapper">
            <select id="category-select" class="custom-select">
              {categories.map((cat) => (
                <option value={cat === 'TODOS' ? 'all' : cat}>{cat}</option>
              ))}
            </select>
            <div class="select-icon">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <div class="projects-grid-container">
        <div class="projects-grid" id="projects-grid">
          {sortedProjects.map((project) => (
            <div class="grid-item" data-category={project.data.category}>
              <ProjectCard project={project} />
            </div>
          ))}
        </div>
        <div class="no-results" id="no-results">No se han encontrado proyectos en esta categoría.</div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .projects-hero {
    padding: 15rem 0 5rem;
    background: #000;
  }

  .hero-tag {
    font-family: var(--font-alt);
    font-size: 0.7rem;
    letter-spacing: 0.8em;
    color: rgba(255,255,255,0.4);
    display: block;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 15vw, 10rem);
    line-height:0.8;
    letter-spacing: 0.05em;
    margin: 0;
    /* Letras huecas (solo contorno) */
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255,255,255,0.9);
  }

  .projects-main {
    background: #000;
    padding-bottom: 0;
  }

  /* Filter Bar */
  .filter-wrapper {
    margin-bottom: 8rem;
    padding: 0 5%;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 1rem;
  }

  .filter-btn {
    background: none;
    border: none;
    color: rgba(255,255,255,0.3);
    cursor: pointer;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.5rem 0;
    transition: color 0.4s ease;
    position: relative;
  }

  .filter-btn::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background: #fff;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .filter-btn:hover {
    color: rgba(255,255,255,0.6);
  }

  .filter-btn.active {
    color: #fff;
  }

  .filter-btn.active::after {
    width: 100%;
  }

  .btn-num {
    font-family: var(--font-alt);
    font-size: 0.5rem;
    opacity: 0.3;
    letter-spacing: 0.1em;
  }

  .btn-label {
    font-family: var(--font-main);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    font-weight: 300;
  }

  /* Mobile Filter */
  .mobile-filter {
    display: none;
    width: 100%;
    margin-bottom: 2rem;
  }

  .select-wrapper {
    position: relative;
    width: 100%;
    border-bottom: 1px solid rgba(255,255,255,0.2);
  }

  .custom-select {
    width: 100%;
    background: transparent;
    color: white;
    font-family: var(--font-main);
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 1rem 2rem 1rem 0;
    border: none;
    appearance: none;
    outline: none;
    cursor: pointer;
  }

  .custom-select option {
    background: #0a0a0a;
    color: white;
    padding: 1rem;
  }

  .select-icon {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: rgba(255,255,255,0.5);
  }

  /* Grid */
  .container.full-width {
    max-width: 100%;
    padding: 0;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    transition: opacity 0.4s ease;
  }

  .grid-item {
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .grid-item.hidden {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    pointer-events: none;
    position: absolute;
    visibility: hidden;
  }

  .no-results {
    display: none;
    text-align: center;
    padding: 10rem 0;
    font-family: var(--font-alt);
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  @media (max-width: 1200px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .projects-hero { padding-top: 10rem; }
    .hero-title { font-size: 4rem; }
    .projects-grid { grid-template-columns: 1fr; }
    
    .filter-bar { display: none; }
    .mobile-filter { display: block; }
  }
</style>

<script>
  function initFilters() {
    const btns = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.grid-item');
    const grid = document.getElementById('projects-grid');
    const noResults = document.getElementById('no-results');
    const select = document.getElementById('category-select') as HTMLSelectElement;

    function applyFilter(filter: string) {
      let visibleCount = 0;

      // Filtering
      items.forEach(item => {
        const cat = item.getAttribute('data-category');
        if (filter === 'all' || cat === filter) {
          item.classList.remove('hidden');
          visibleCount++;
        } else {
          item.classList.add('hidden');
        }
      });

      // Toggle Grid/No-Results
      if (visibleCount === 0) {
        if (grid) grid.style.display = 'none';
        if (noResults) noResults.style.display = 'block';
      } else {
        if (grid) grid.style.display = 'grid';
        if (noResults) noResults.style.display = 'none';
      }

      // Trigger reveal animations
      window.dispatchEvent(new Event('scroll'));
    }

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Active state
        btns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        const filter = btn.getAttribute('data-category');
        if(select) select.value = filter || 'all';
        applyFilter(filter || 'all');
      });
    });

    if (select) {
      select.addEventListener('change', (e) => {
        const filter = (e.target as HTMLSelectElement).value;
        
        // Sync desktop buttons
        btns.forEach(b => {
          if (b.getAttribute('data-category') === filter) {
            b.classList.add('active');
          } else {
            b.classList.remove('active');
          }
        });
        
        applyFilter(filter);
      });
    }
  }

  document.addEventListener('astro:page-load', initFilters);
  initFilters();

  // ===== Preview en vídeo de los proyectos =====
  // Bucle de YouTube vía API (sin playlist -> sin botones anterior/siguiente ni pantalla final)
  if (!(window as any).__ytLoop) {
    (window as any).__ytLoop = true;
    window.addEventListener('message', (e: MessageEvent) => {
      if (typeof e.data !== 'string' || e.data.indexOf('onStateChange') === -1) return;
      let d: any;
      try { d = JSON.parse(e.data); } catch (_) { return; }
      // info === 0 => el vídeo ha terminado: reiniciar
      if (d && d.event === 'onStateChange' && d.info === 0 && e.source) {
        (e.source as Window).postMessage('{"event":"command","func":"seekTo","args":[0,true]}', '*');
        (e.source as Window).postMessage('{"event":"command","func":"playVideo","args":[]}', '*');
      }
    });
  }

  function initPreviews() {
    const cards = document.querySelectorAll<HTMLElement>('.project-card');
    if (!cards.length) return;
    const isTouch = window.matchMedia('(hover: none)').matches;

    const play = (card: HTMLElement) => {
      const holder = card.querySelector<HTMLElement>('.preview');
      if (!holder) return;
      const timer = (holder as any)._stopTimer;
      if (timer) { clearTimeout(timer); (holder as any)._stopTimer = null; }
      if (!holder.dataset.loaded) {
        const src = holder.dataset.preview;
        if (!src) return;
        const isYT = holder.classList.contains('is-youtube');
        const iframe = document.createElement('iframe');
        iframe.src = src;
        iframe.allow = 'autoplay; fullscreen';
        iframe.tabIndex = -1;
        iframe.setAttribute('aria-hidden', 'true');
        // Estilos inline (los estilos scoped de Astro no aplican a elementos inyectados)
        iframe.style.cssText =
          'position:absolute;top:0;left:0;width:100%;height:100%;border:0;background:#000;' +
          'transform-origin:center;transform:scale(1.0);';
        if (isYT) {
          // Activa la API para poder reiniciar el vídeo en bucle al terminar
          iframe.addEventListener('load', () => {
            try { iframe.contentWindow?.postMessage('{"event":"listening"}', '*'); } catch (_) {}
          });
        }
        holder.appendChild(iframe);
        holder.dataset.loaded = '1';
      }
      // Retraso: deja que el vídeo arranque antes de mostrarlo (oculta el boton central inicial)
      const delay = holder.classList.contains('is-youtube') ? 650 : 60;
      (holder as any)._showTimer = setTimeout(() => holder.classList.add('is-playing'), delay);
    };

    const stop = (card: HTMLElement) => {
      const holder = card.querySelector<HTMLElement>('.preview');
      if (!holder) return;
      if ((holder as any)._showTimer) { clearTimeout((holder as any)._showTimer); (holder as any)._showTimer = null; }
      holder.classList.remove('is-playing');
      (holder as any)._stopTimer = setTimeout(() => {
        const f = holder.querySelector('iframe');
        if (f) f.remove();
        holder.dataset.loaded = '';
        (holder as any)._stopTimer = null;
      }, 600);
    };

    if (!isTouch) {
      cards.forEach(card => {
        if ((card as any)._previewBound) return;
        (card as any)._previewBound = true;
        card.addEventListener('mouseenter', () => play(card));
        card.addEventListener('mouseleave', () => stop(card));
      });
    } else {
      // Móvil: reproduce la tarjeta más visible en pantalla
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting && e.intersectionRatio >= 0.65) play(e.target as HTMLElement);
          else stop(e.target as HTMLElement);
        });
      }, { threshold: [0, 0.65, 1] });
      cards.forEach(card => {
        if ((card as any)._previewBound) return;
        (card as any)._previewBound = true;
        io.observe(card);
      });
    }
  }

  document.addEventListener('astro:page-load', initPreviews);
  initPreviews();
</script>
