---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Juan Alcaraz | Cineasta y Director Audiovisual';
const pageDescription =
  'Portfolio oficial de Juan Alcaraz, director de cine, cortometrajes, spots y vídeos creativos en Murcia.';

const VIMEO_REEL_ID = '1175433396';

// Datos estructurados: el reel de la portada como obra en vídeo
const videoLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: 'Reel de Juan Alcaraz — Cineasta y Director Audiovisual',
  description:
    'Selección de trabajos de dirección de Juan Alcaraz: ficción, videoclips y publicidad.',
  thumbnailUrl: `https://vumbnail.com/${VIMEO_REEL_ID}.jpg`,
  embedUrl: `https://player.vimeo.com/video/${VIMEO_REEL_ID}`,
  creator: { '@id': 'https://juanalcaraz.es/#person' },
};
---

<Layout title={pageTitle} description={pageDescription} preconnectVimeo jsonLd={videoLd}>
  <section class="hero">
    <h1 class="visually-hidden">Juan Alcaraz — Cineasta y Director Audiovisual en Murcia</h1>
    <div class="video-background">
      <iframe
        id="hero-video"
        src={`https://player.vimeo.com/video/${VIMEO_REEL_ID}?background=1&autoplay=1&playsinline=1&autopause=0&loop=1&muted=1&title=0&portrait=0&byline=0`}
        title="Reel de Juan Alcaraz, cineasta y director audiovisual"
        allow="autoplay; fullscreen"
        allowfullscreen
      ></iframe>
    </div>
    <div class="hero-loader" id="hero-loader" aria-hidden="true">
      <span class="hero-ring"></span>
    </div>
  </section>


</Layout>

<style>
  .hero {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    background: #000;
  }

  .video-background {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100vw;
    height: 56.25vw;
    min-height: 100vh;
    min-width: 177.77vh;
    /* Zoom hasta cubrir toda la pantalla (sin huecos) */
    transform: translate(-50%, -50%) scale(1.05);
    pointer-events: none;
    z-index: 1;
  }

  .video-background iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Indicador de carga (se funde cuando el vídeo arranca) */
  .hero-loader {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.9s ease;
    pointer-events: none;
  }

  .hero-loader.is-hidden {
    opacity: 0;
  }

  .hero-ring {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-top-color: rgba(255, 255, 255, 0.8);
    animation: hero-spin 0.9s linear infinite;
  }

  @keyframes hero-spin {
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-ring { animation: none; }
  }
</style>

<script is:inline defer src="https://player.vimeo.com/api/player.js"></script>
<script>
  function initHeroLoader() {
    const loader = document.getElementById('hero-loader');
    const iframe = document.getElementById('hero-video') as HTMLIFrameElement | null;
    if (!loader || !iframe || (loader as any)._init) return;
    (loader as any)._init = true;

    let done = false;
    const hide = () => { if (done) return; done = true; loader.classList.add('is-hidden'); };

    // Deteccion fiable con el SDK de Vimeo (con reintento hasta que cargue)
    let tries = 0;
    const attach = () => {
      const Vimeo = (window as any).Vimeo;
      if (Vimeo && Vimeo.Player) {
        try {
          const player = new Vimeo.Player(iframe);
          player.on('timeupdate', hide); // se dispara solo cuando el video avanza (ya se ve)
          player.on('playing', hide);
          player.on('bufferend', hide);
        } catch (_) {}
      } else if (tries++ < 20) {
        setTimeout(attach, 150);
      }
    };
    attach();

    // Fallback por si el SDK no carga o tarda demasiado
    setTimeout(hide, 6000);
  }

  document.addEventListener('astro:page-load', initHeroLoader);
  initHeroLoader();
</script>
