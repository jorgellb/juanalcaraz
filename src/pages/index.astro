---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Juan Alcaraz | Cineasta y Director Audiovisual" 
  description="Portfolio oficial de Juan Alcaraz, director de cine, cortometrajes, spots y vídeos creativos en Murcia."
>
  <section class="hero">
    <h1 class="visually-hidden">Juan Alcaraz — Cineasta y Director Audiovisual en Murcia</h1>
    <div class="video-blur" aria-hidden="true">
      <iframe
        src="https://player.vimeo.com/video/1175433396?background=1&autoplay=1&playsinline=1&color&autopause=0&loop=1&muted=1&title=0&portrait=0&byline=0"
        tabindex="-1"
        allow="autoplay; fullscreen"
      ></iframe>
    </div>
    <div class="video-background">
      <iframe
        src="https://player.vimeo.com/video/1175433396?background=1&autoplay=1&playsinline=1&color&autopause=0&loop=1&muted=1&title=0&portrait=0&byline=0"
        title="Reel de Juan Alcaraz, cineasta y director audiovisual"
        allow="autoplay; fullscreen"
        allowfullscreen
      ></iframe>
    </div>
  </section>


</Layout>

<style>
  .hero {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    background: #000;
  }

  .video-background {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100vw;
    height: 56.25vw;
    min-height: 100vh;
    min-width: 177.77vh;
    transform: translate(-50%, -50%) scale(0.9);
    pointer-events: none;
    z-index: 1;
  }

  .video-background iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Fondo desenfocado que rellena los huecos laterales sin agrandar el video nitido */
  .video-blur {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100vw;
    height: 56.25vw;
    min-height: 100vh;
    min-width: 177.77vh;
    transform: translate(-50%, -50%) scale(1.15);
    pointer-events: none;
    z-index: 0;
    filter: blur(35px) brightness(0.55) saturate(1.1);
  }

  .video-blur iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  @media (max-width: 768px) {
    .video-background {
      /* Cubre toda la pantalla en movil (sin franjas negras) */
      transform: translate(-50%, -50%) scale(1.05);
    }
    /* En movil ya cubre toda la pantalla: no hace falta el fondo desenfocado */
    .video-blur {
      display: none;
    }
  }
</style>

