---
const currentYear = new Date().getFullYear();

const legalLinks = [
  { href: '/aviso-legal', label: 'Aviso legal' },
  { href: '/privacidad', label: 'Privacidad' },
  { href: '/cookies', label: 'Cookies' }
];
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-main">
      <div class="footer-brand">
        <a href="/" class="footer-logo">JU<i>A</i>N <i>A</i>LC<i>A</i>R<i>A</i>Z</a>
        <p class="footer-tagline">Cineasta y director audiovisual</p>
      </div>
      
      <nav class="footer-nav" aria-label="Navegación footer">
        <ul class="footer-nav-list">
          <li><a href="/">Inicio</a></li>
          <li><a href="/proyectos">Proyectos</a></li>
          <li><a href="/biofilmografia">Filmografía</a></li>
          <li><a href="/contacto">Contacto</a></li>
        </ul>
      </nav>
      
      <nav class="footer-legal" aria-label="Legal">
        <ul class="footer-legal-list">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
    
    <div class="footer-bottom">
      <p class="copyright">&copy; {currentYear} Juan Alcaraz. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding: var(--spacing-3xl) 0 var(--spacing-xl);
    margin-top: auto;
  }
  
  .footer-container {
    max-width: var(--max-width-xl);
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
  }
  
  .footer-main {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--spacing-2xl);
    margin-bottom: var(--spacing-2xl);
  }
  
  .footer-logo {
    font-family: var(--font-logo);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-tight);
    text-transform: uppercase;
    color: var(--color-text);
    display: block;
    margin-bottom: var(--spacing-sm);
  }
  
  .footer-logo i {
    font-style: italic;
    font-weight: inherit;
  }
  
  .footer-tagline {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }
  
  .footer-nav-list,
  .footer-legal-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }
  
  .footer-nav-list a,
  .footer-legal-list a {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    transition: color var(--transition-fast);
  }
  
  .footer-nav-list a:hover,
  .footer-legal-list a:hover {
    color: var(--color-text);
  }
  
  .footer-bottom {
    padding-top: var(--spacing-xl);
    border-top: 1px solid var(--color-border);
  }
  
  .copyright {
    font-size: var(--font-size-xs);
    color: var(--color-text-light);
    text-align: center;
  }
  
  @media (max-width: var(--breakpoint-md)) {
    .footer-main {
      grid-template-columns: 1fr;
      gap: var(--spacing-xl);
      text-align: center;
    }
    
    .footer-nav-list,
    .footer-legal-list {
      align-items: center;
    }
  }
</style>
