---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Inicio', sub: 'Home reel' },
  { href: '/proyectos', label: 'Proyectos', sub: 'Projects' },
  { href: '/biofilmografia', label: 'Filmografía', sub: 'Filmography' },
  { href: '/contacto', label: 'Contacto', sub: 'Write the future' }
];
---

<header class="header" id="main-header">
  <div class="header-inner">
    <div class="logo-container">
      <a href="/" class="logo-link">
        <h2 class="elementor-heading-title premium-logo">JU<i>A</i>N <i>A</i>LC<i>A</i>R<i>A</i>Z</h2>
      </a>
      <span class="role flicker-slow">CINE<i>A</i>ST<i>A</i></span>
    </div>

    <button class="menu-btn" id="menu-toggle" aria-label="Abrir menú">
      <div class="btn-hover-bg"></div>
      <span class="menu-text">EXPLORE</span>
      <div class="hamburger">
        <span class="line l1"></span>
        <span class="line l2"></span>
      </div>
    </button>
  </div>

  <nav class="full-menu" id="full-menu">
    <div class="menu-background">
      <div class="vignette"></div>
      <div class="noise"></div>
    </div>
    <div class="menu-content">
      <div class="menu-nav">
        <ul class="nav-list">
          {navItems.map((item, index) => (
            <li class="nav-item">
              <a href={item.href} class:list={['nav-link', { active: currentPath === item.href }]}>
                <span class="nav-index">0{index + 1}</span>
                <div class="nav-text-container">
                  <span class="nav-label">{item.label}</span>
                  <span class="nav-sub">{item.sub}</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="menu-footer">
        <div class="social-row">
          <a href="https://instagram.com/juanalcarazcine" target="_blank" class="f-link">INSTAGRAM</a>
          <span class="sep">/</span>
          <a href="mailto:juanalcarazcine@gmail.com" class="f-link">JUANALCARAZCINE@GMAIL.COM</a>
        </div>
        <div class="legal-row">
          <a href="/aviso-legal" class="l-link">AVISO LEGAL</a>
          <span class="sep">·</span>
          <a href="/politica-privacidad" class="l-link">POLÍTICA PRIVACIDAD</a>
          <span class="sep">·</span>
          <a href="/politica-cookies" class="l-link">POLÍTICA COOKIES</a>
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 3.5rem 5%;
    transition: all 0.8s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .header.scrolled {
    padding: 1.8rem 5%;
    background: rgba(0,0,0,0.1);
    backdrop-filter: blur(10px);
  }

  .header-inner {
    max-width: 1800px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 1002; /* Stay above everything */
  }

  /* Logo Magic */
  .logo-link {
    text-decoration: none;
    color: #ffffff;
    display: block;
    mix-blend-mode: difference;
  }

  .premium-logo {
    font-family: var(--font-logo);
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin: 0;
    line-height: 1;
    transition: all 1.8s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .logo-link:hover .premium-logo {
    letter-spacing: 0.12em;
  }

  .role {
    font-family: var(--font-logo);
    font-size: 0.6rem;
    letter-spacing: 1.8em;
    color: #ffffff;
    text-transform: uppercase;
    opacity: 0.6;
    margin-top: 0.8rem;
    display: block;
    padding-left: 1.8em;
    mix-blend-mode: difference;
  }

  /* Target all italicized letters inside logo elements */
  .premium-logo i, .role i {
    font-style: italic;
    font-weight: inherit;
  }

  /* Menu Toggle Button */
  .menu-btn {
    background: none;
    border: none;
    padding: 1rem 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 2rem;
    color: white;
    position: relative;
    mix-blend-mode: difference;
  }

  .btn-hover-bg {
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.05);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    z-index: -1;
  }

  .menu-btn:hover .btn-hover-bg {
    transform: scaleX(1);
  }

  .menu-text {
    font-family: var(--font-alt);
    font-size: 0.7rem;
    letter-spacing: 0.6em;
    transition: opacity 0.4s ease;
  }

  .hamburger {
    width: 40px;
    height: 12px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .line {
    width: 100%;
    height: 1.5px;
    background: white;
    transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }

  /* Full Screen Menu */
  .full-menu {
    position: fixed;
    inset: 0;
    z-index: 1000;
    visibility: hidden;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .full-menu.open {
    visibility: visible;
    pointer-events: all;
  }

  .menu-background {
    position: absolute;
    inset: 0;
    background: #000;
    opacity: 0;
    transition: opacity 1s ease;
  }

  .full-menu.open .menu-background {
    opacity: 1;
  }

  .vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.9) 100%);
  }

  .noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3%3Ffilter id='n' %3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.05;
    mix-blend-mode: overlay;
  }

  .menu-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1200px;
    padding: 0 5%;
    text-align: center;
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.8s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .full-menu.open .menu-content {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.3s;
  }

  .nav-list {
    list-style: none;
    padding: 0;
  }

  .nav-item {
    margin-bottom: 1.2rem;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 3rem;
    text-decoration: none;
    color: rgba(255,255,255,0.2);
    transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .nav-index {
    font-family: var(--font-alt);
    font-size: 1rem;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.15);
  }

  .nav-label {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 5rem);
    line-height: 1.1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    /* Letras rellenas (solidas) */
    color: rgba(255,255,255,0.35);
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .nav-sub {
    display: block;
    font-family: var(--font-alt);
    font-size: 0.65rem;
    letter-spacing: 0.6em;
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.6s ease;
    margin-top: 0.3rem;
  }

  .nav-link:hover {
    color: white;
  }

  .nav-link:hover .nav-label {
    color: #fff;
    transform: scale(1.05);
  }

  .nav-link:hover .nav-sub {
    opacity: 0.5;
    transform: translateY(0);
  }

  .menu-footer {
    margin-top: 5rem;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s ease;
  }

  .full-menu.open .menu-footer {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.8s;
  }

  .social-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
  }

  .f-link {
    font-family: var(--font-alt);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .f-link:hover {
    color: white;
  }

  .legal-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .l-link {
    font-family: var(--font-alt);
    font-size: 0.5rem;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.2);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .l-link:hover {
    color: rgba(255,255,255,0.6);
  }

  .sep {
    color: rgba(255,255,255,0.1);
  }

  /* Hamburger Active Animation */
  .full-menu.open ~ .header-inner .l1 {
    transform: translateY(5.5px) rotate(45deg);
  }

  .full-menu.open ~ .header-inner .l2 {
    transform: translateY(-5px) rotate(-45deg);
  }

  /* Ajustes para laptops de 15" (resoluciones entre 1024px y 1600px) */
  @media (max-width: 1600px) and (min-width: 1024px) {
    .nav-label {
      font-size: clamp(2rem, 5vw, 3.5rem);
    }
    
    .nav-item {
      margin-bottom: 1rem;
    }
    
    .menu-footer {
      margin-top: 3rem;
    }
    
    .nav-sub {
      font-size: 0.6rem;
      letter-spacing: 0.5em;
    }
  }

  @media (max-width: 768px) {
    .header { padding: 2.5rem 5%; }
    
    .full-menu {
      align-items: flex-start;
      overflow-y: auto;
      overflow-x: hidden;
      -webkit-overflow-scrolling: touch;
    }

    .menu-background {
      position: fixed;
    }

    .menu-content {
      padding-top: 10rem;
      padding-bottom: 5rem;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }

    .nav-index { 
      display: none; 
    }
    
    .nav-link { 
      gap: 0; 
      justify-content: center;
      width: 100%;
    }

    .nav-text-container {
      width: 100%;
      text-align: center;
    }

    .nav-label {
      font-size: 2.2rem;
      letter-spacing: 0.1em;
      /* En movil las letras huecas no se leen bien: solidas */
      color: rgba(255,255,255,0.92);
      -webkit-text-stroke: 0;
    }

    .nav-link:hover .nav-label,
    .nav-link.active .nav-label {
      color: #fff;
    }
    
    .nav-sub { 
      font-size: 0.6rem; 
      letter-spacing: 0.5em; 
      margin-top: 0.4rem; 
      opacity: 0.4;
      transform: translateY(0);
    }
    
    .nav-item { margin-bottom: 2rem; }
    
    .menu-text { display: none; }
    .premium-logo { font-size: 1.6rem; }
    .role { font-size: 0.5rem; }
    
    .menu-footer { margin-top: 2rem; }
    
    .social-row, .legal-row {
      flex-direction: column;
      gap: 1.2rem;
    }
    
    .social-row .sep, .legal-row .sep {
      display: none;
    }
  }
</style>

<script>
  function initMenu() {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('full-menu');
    const navLinks = document.querySelectorAll('.nav-link');
    let isOpen = false;

    if (!toggle || !menu) return;

    // Remove existing event listeners if any (though astro:page-load handles this usually)
    toggle.replaceWith(toggle.cloneNode(true));
    const newToggle = document.getElementById('menu-toggle');

    function toggleMenu() {
      isOpen = !isOpen;
      menu?.classList.toggle('open');
      document.body.style.overflow = isOpen ? 'hidden' : '';
    }

    newToggle?.addEventListener('click', toggleMenu);

    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (isOpen) {
          toggleMenu();
        }
      });
    });
  }

  // Initialize on first load
  initMenu();

  // Re-initialize after navigation
  document.addEventListener('astro:page-load', initMenu);
</script>

